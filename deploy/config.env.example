# Copy to a local config file and fill in values.
# This file is not meant to be committed with secrets.

# Initial SSH user with sudo privileges
ROOT_USER=root

# App runtime user to create and use
APP_USER=foucl
VPS_HOST=example.vps

# App root (all app data lives under this)
APP_ROOT=/home/foucl/apps

# SSH public key to install for APP_USER
SSH_PUBKEY_PATH=/home/dev/.ssh/id_rsa.pub

DOMAIN=example.com
ACME_EMAIL=admin@example.com

# Runtime env values (used to generate runtime.env)
FOUCL_SESSION_SECRET=replace_me
FOUCL_CONFIG_FILE=/home/foucl/apps/foucl/config/app-config.json
FOUCL_SESSION_COOKIE_SECURE=true

# Local paths for deployment
LOCAL_FRONTEND_FILES=/home/dev/workspace/favs-frontend2/static
BACKEND_BINARY=/home/dev/workspace/foucl2/dist-newstyle/build/.../foucl
# Must point to a JSON file that contains a non-empty:
# { "auth": { "bootstrapAdminUsername": "..." } }
BACKEND_CONFIG_FILE=/home/dev/workspace/foucl2/config/app-config.json

# Backup destination on dev machine
BACKUP_DEST=/home/dev/backup/foucl-data
